  staffId  String
  schoolId String

  caseNumber  String          @unique
  subject     String
  description String          @db.Text
  status      GrievanceStatus @default(SUBMITTED)
  isAnonymous Boolean         @default(false)

  handledById String?
  handledBy   Staff?  @relation("GrievanceHandledBy", fields: [handledById], references: [id])

  investigationNotes String?   @db.Text
  mediationNotes     String?   @db.Text
  resolutionDetails  String?   @db.Text
  resolvedAt         DateTime?

  escalatedAt     DateTime?
  escalatedTo     String?
  escalationNotes String?   @db.Text

  documentUrls String[]
  closedAt     DateTime?

  staff Staff @relation("GrievanceRaisedBy", fields: [staffId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([staffId])
  @@index([schoolId])
  @@index([status])
}

model StaffDocument {
  id       String @id @default(cuid())
  staffId  String
  schoolId String

  category    DocumentCategory
  name        String
  description String?
  fileUrl     String
  fileType    String?
  fileSizeKb  Int?

  issueDate  DateTime?
  expiryDate DateTime?
  isVerified Boolean   @default(false)

  verifiedById String?
  verifiedBy   User?     @relation("DocumentVerifiedBy", fields: [verifiedById], references: [id])
  verifiedAt   DateTime?

  isConfidential Boolean @default(false)

  uploadedById String?
  uploadedBy   User?   @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([staffId])
  @@index([schoolId])
  @@index([category])
  @@index([expiryDate])
}

model TrainingProgram {
  id       String @id @default(cuid())
  schoolId String

  title        String
  description  String?        @db.Text
  trainingType TrainingType
  status       TrainingStatus @default(PLANNED)
  provider     String?
  venue        String?
  isOnline     Boolean        @default(false)
  onlineLink   String?

  startDate       DateTime
  endDate         DateTime
  totalHours      Float?
  maxParticipants Int?
  cost            Float?
  costPerStaff    Float?

  certificateIssued Boolean @default(false)
  certificateUrl    String?

  targetRoles String[]
  skills      String[]

  createdById String?
  createdBy   User?   @relation("TrainingCreatedBy", fields: [createdById], references: [id])

  school       School                @relation("SchoolTrainingPrograms", fields: [schoolId], references: [id], onDelete: Cascade)
  participants TrainingParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([status])
  @@index([trainingType])
  @@index([startDate])
}

model TrainingParticipant {
  id         String @id @default(cuid())
  trainingId String
  staffId    String
  schoolId   String

  status        TrainingStatus @default(PLANNED)
  registeredAt  DateTime       @default(now())
  attendedHours Float?
  completedAt   DateTime?
  grade         String?
  score         Float?
  passed        Boolean?

  certificateUrl      String?
  certificateIssuedAt DateTime?
  feedback            String?   @db.Text
  trainerFeedback     String?   @db.Text

  training TrainingProgram @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  staff    Staff           @relation(fields: [staffId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([trainingId, staffId])
  @@index([trainingId])
  @@index([staffId])
  @@index([schoolId])
}

model StaffNotice {
  id       String @id @default(cuid())
  schoolId String

  title    String
  content  String         @db.Text
  status   NoticeStatus   @default(DRAFT)
  audience NoticeAudience @default(ALL_STAFF)
  isPinned Boolean        @default(false)
  priority String         @default("NORMAL")

  targetRoleIds  String[]
  targetStaffIds String[]

  publishedAt    DateTime?
  expiresAt      DateTime?
  attachmentUrls String[]

  requiresAcknowledgement Boolean @default(false)

  createdById String
  createdBy   Staff  @relation("NoticeCreatedBy", fields: [createdById], references: [id])

  school           School                  @relation("SchoolNotices", fields: [schoolId], references: [id], onDelete: Cascade)
  acknowledgements NoticeAcknowledgement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([status])
  @@index([audience])
  @@index([isPinned])
  @@index([publishedAt])
  @@index([expiresAt])
}

model NoticeAcknowledgement {
  id       String @id @default(cuid())
  noticeId String
  staffId  String
  schoolId String

  acknowledgedAt DateTime @default(now())
  deviceInfo     String?

  notice StaffNotice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  staff  Staff       @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([noticeId, staffId])
  @@index([noticeId])
  @@index([staffId])
}

model ExitRecord {
  id       String @id @default(cuid())
  staffId  String @unique
  schoolId String

  exitType       ExitType
  status         ExitStatus @default(INITIATED)
  exitDate       DateTime
  noticeDate     DateTime?
  lastWorkingDay DateTime?

  primaryReason        String?  @db.Text
  feedbackOnSchool     String?  @db.Text
  feedbackOnManagement String?  @db.Text
  feedbackOnTeamwork   String?  @db.Text
  wouldRecommendSchool Boolean?
  suggestions          String?  @db.Text

  clearedLibrary  Boolean @default(false)
  clearedStore    Boolean @default(false)
  clearedAccounts Boolean @default(false)
  clearedIT       Boolean @default(false)
  clearedHR       Boolean @default(false)
  assetsReturned  Boolean @default(false)
  clearanceNotes  String? @db.Text

  finalSalaryPaid      Boolean @default(false)
  gratuityAmount       Float?
  gratuityPaid         Boolean @default(false)
  noticePeriodPaid     Boolean @default(false)
  otherSettlementNotes String?

  experienceLetterIssued Boolean @default(false)
  experienceLetterUrl    String?
  releasingLetterIssued  Boolean @default(false)
  releasingLetterUrl     String?
  recommendationIssued   Boolean @default(false)

  interviewConductedById String?
  interviewConductedBy   User?     @relation("ExitInterviewBy", fields: [interviewConductedById], references: [id])
  interviewDate          DateTime?

  approvedById String?
  approvedBy   User?     @relation("ExitApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  completedAt  DateTime?

  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([status])
  @@index([exitType])
  @@index([exitDate])
}

// ════════════════════════════════════════════════════════════════════════════
// COMMUNICATIONS & EVENTS — UNCHANGED
// ════════════════════════════════════════════════════════════════════════════

enum MessageChannel {
  SYSTEM
  EMAIL
  SMS
}

enum MessageAudience {
  ALL
  PARENTS
  TEACHERS
  ALL_STAFF
  SPECIFIC_USERS
}

enum MessageStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  PARTIALLY_SENT
  FAILED
  CANCELLED
}

enum MessagePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum DeliveryStatus {
  PENDING
  DELIVERED
  READ
  FAILED
  BOUNCED
  OPTED_OUT
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
  POSTPONED
}

enum EventAudience {
  ALL
  PARENTS
  TEACHERS
  ALL_STAFF
  STUDENTS
  PUBLIC
}

enum EventType {
  ACADEMIC
  SPORTS
  CULTURAL
  PARENTS_MEETING
  STAFF_MEETING
  HOLIDAY
  TRIP
  FUNDRAISING
  HEALTH
  OTHER
}

model Message {
  id       String @id @default(cuid())
  schoolId String

  subject  String
  body     String  @db.Text
  bodyHtml String? @db.Text

  channels MessageChannel[]

  audience         MessageAudience @default(ALL)
  recipientUserIds String[]

  targetClassYearIds String[]
  targetStreamIds    String[]

  priority MessagePriority @default(NORMAL)
  status   MessageStatus   @default(DRAFT)

  scheduledAt DateTime?
  sentAt      DateTime?

  attachmentUrls String[]

  totalRecipients Int @default(0)
  deliveredCount  Int @default(0)
  readCount       Int @default(0)
  failedCount     Int @default(0)

  createdById String
  createdBy   User   @relation("MessageCreatedBy", fields: [createdById], references: [id])

  school      School              @relation("SchoolMessages", fields: [schoolId], references: [id], onDelete: Cascade)
  deliveries  MessageDelivery[]
  systemPosts SystemMessagePost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([status])
  @@index([audience])
  @@index([scheduledAt])
  @@index([createdById])
}

model MessageDelivery {
  id        String @id @default(cuid())
  messageId String
  userId    String

  channel       MessageChannel
  status        DeliveryStatus @default(PENDING)
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  failureReason String?
  retryCount    Int            @default(0)
  externalRef   String?

  recipientName  String?
  recipientEmail String?
  recipientPhone String?

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation("MessageDeliveries", fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([messageId, userId, channel])
  @@index([messageId])
  @@index([userId])
  @@index([status])
  @@index([channel])
  @@index([sentAt])
}

model SystemMessagePost {
  id        String @id @default(cuid())
  messageId String
  userId    String

  isRead     Boolean   @default(false)
  readAt     DateTime?
  isStarred  Boolean   @default(false)
  isArchived Boolean   @default(false)
  deletedAt  DateTime?

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation("SystemMessagePosts", fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@index([isRead])
  @@index([isArchived])
}

model SchoolEvent {
  id       String @id @default(cuid())
  schoolId String

  title       String
  description String?     @db.Text
  eventType   EventType
  status      EventStatus @default(DRAFT)

  audience EventAudience @default(ALL)

  startDate DateTime
  endDate   DateTime
  allDay    Boolean  @default(false)
  location  String?
  onlineUrl String?

  colorTag String?

  isRecurring       Boolean   @default(false)
  recurrenceRule    String?
  recurrenceEndDate DateTime?

  attachmentUrls String[]
  coverImageUrl  String?
  isPinned       Boolean  @default(false)

  publishedAt DateTime?

  createdById String
  createdBy   User   @relation("EventCreatedBy", fields: [createdById], references: [id])

  school    School          @relation("SchoolEvents", fields: [schoolId], references: [id], onDelete: Cascade)
  rsvps     EventRSVP[]
  reminders EventReminder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([status])
  @@index([eventType])
  @@index([audience])
  @@index([startDate])
  @@index([isPinned])
}

model EventRSVP {
  id      String @id @default(cuid())
  eventId String
  userId  String

  response    String   @default("ATTENDING")
  notes       String?
  respondedAt DateTime @default(now())

  event SchoolEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User        @relation("EventRSVPs", fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model EventReminder {
  id      String @id @default(cuid())
  eventId String

  minutesBefore Int @default(1440)

  channels MessageChannel[]
  audience EventAudience    @default(ALL)

  isSent Boolean   @default(false)
  sentAt DateTime?

  event SchoolEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([isSent])
}

model NotificationPreference {
  id       String @id @default(cuid())
  userId   String
  schoolId String

  systemEnabled Boolean @default(true)
  emailEnabled  Boolean @default(true)
  smsEnabled    Boolean @default(false)

  receiveSchoolMessages   Boolean @default(true)
  receiveEventReminders   Boolean @default(true)
  receiveFeeAlerts        Boolean @default(true)
  receiveGradeReports     Boolean @default(true)
  receiveAttendanceAlerts Boolean @default(true)
  receiveStaffNotices     Boolean @default(true)
  receiveAnnouncements    Boolean @default(true)

  quietHoursEnabled Boolean @default(false)
  quietHoursStart   String?
  quietHoursEnd     String?

  digestEnabled   Boolean @default(false)
  digestFrequency String  @default("DAILY")

  user   User   @relation("UserNotificationPrefs", fields: [userId], references: [id], onDelete: Cascade)
  school School @relation("SchoolNotificationPrefs", fields: [schoolId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, schoolId])
  @@index([userId])
  @@index([schoolId])
}

model AppNotification {
  id       String @id @default(cuid())
  userId   String
  schoolId String

  title     String
  body      String
  actionUrl String?
  iconType  String?

  isRead Boolean   @default(false)
  readAt DateTime?

  sourceType String?
  sourceId   String?

  expiresAt DateTime?

  user   User   @relation("AppNotifications", fields: [userId], references: [id], onDelete: Cascade)
  school School @relation("SchoolAppNotifications", fields: [schoolId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([schoolId])
  @@index([createdAt])
  @@index([sourceType, sourceId])
}

// ════════════════════════════════════════════════════════════════════════════
// GENERAL AUDIT LOG
// Tracks all entity-level changes across the system (not just marks).
// MarkAuditLog remains for mark-specific audit with richer mark context.
// ════════════════════════════════════════════════════════════════════════════

model AuditLog {
  id       String  @id @default(cuid())
  schoolId String?
  userId   String?

  action   String // CREATE | UPDATE | DELETE | LOGIN | EXPORT etc.
  entity   String // Model name e.g. "Student", "Invoice", "Staff"
  entityId String?

  oldValues Json?
  newValues Json?

  ipAddress String?
  userAgent String?

  performedAt DateTime @default(now())

  @@index([schoolId])
  @@index([userId])
  @@index([entity, entityId])
  @@index([performedAt])
}

// ════════════════════════════════════════════════════════════════════════════
// STAFF DEPARTMENTS
// Groups staff by academic or administrative department.
// ════════════════════════════════════════════════════════════════════════════

model Department {
  id          String  @id @default(cuid())
  schoolId    String
  school      School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name        String
  code        String?
  description String?
  isActive    Boolean @default(true)

  members DepartmentMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([isActive])
}

model DepartmentMember {
  id           String     @id @default(cuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  staffId      String
  staff        Staff      @relation(fields: [staffId], references: [id], onDelete: Cascade)

  isHead   Boolean   @default(false)
  joinedAt DateTime  @default(now())
  leftAt   DateTime?
  notes    String?

  @@unique([departmentId, staffId])
  @@index([departmentId])
  @@index([staffId])
}

// ════════════════════════════════════════════════════════════════════════════
// LIBRARY
// Book/resource catalogue and student borrowing records.
// ════════════════════════════════════════════════════════════════════════════

enum LibraryItemStatus {
  AVAILABLE
  BORROWED
  RESERVED
  DAMAGED
  LOST
}

enum LibraryItemCategory {
  TEXTBOOK
  REFERENCE
  NOVEL
  PERIODICAL
  MAGAZINE
  MAP
  DVD
  OTHER
}

model LibraryItem {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  title     String
  author    String?
  isbn      String?
  publisher String?
  edition   String?
  year      Int?

  category LibraryItemCategory @default(OTHER)
  status   LibraryItemStatus   @default(AVAILABLE)

  totalCopies     Int @default(1)
  availableCopies Int @default(1)

  shelfLocation String?
  coverImageUrl String?
  notes         String?
  isActive      Boolean @default(true)

  borrows LibraryBorrow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([status])
  @@index([category])
  @@index([isbn])
}

model LibraryBorrow {
  id            String      @id @default(cuid())
  libraryItemId String
  libraryItem   LibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)

  // Either a student OR a staff member can borrow
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  staffId String?
  staff   Staff?  @relation("StaffLibraryBorrows", fields: [staffId], references: [id], onDelete: SetNull)

  borrowedAt DateTime  @default(now())
  dueDate    DateTime
  returnedAt DateTime?

  isOverdue   Boolean @default(false)
  lateFeeOwed Float?
  lateFeepaid Boolean @default(false)

  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([libraryItemId])
  @@index([studentId])
  @@index([staffId])
  @@index([dueDate])
  @@index([returnedAt])
}

// ════════════════════════════════════════════════════════════════════════════
// TRANSPORT
// School vehicles, routes, and student route assignments.
// ════════════════════════════════════════════════════════════════════════════

enum TransportDirection {
  TO_SCHOOL
  FROM_SCHOOL
  BOTH
}

enum VehicleStatus {
  ACTIVE
  UNDER_MAINTENANCE
  RETIRED
  DISPOSED
}

model Vehicle {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  registrationNo String        @unique
  make           String?
  model          String?
  year           Int?
  capacity       Int?
  color          String?
  status         VehicleStatus @default(ACTIVE)

  insuranceExpiry  DateTime?
  inspectionExpiry DateTime?
  notes            String?

  routes TransportRoute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([status])
}

model TransportRoute {
  id        String  @id @default(cuid())
  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  schoolId    String
  name        String
  description String?
  direction   TransportDirection @default(BOTH)

  morningDepartureTime String? // e.g. "06:30"
  eveningDepartureTime String? // e.g. "17:00"

  stopsJson String? // JSON array of stop names/coordinates
  isActive  Boolean @default(true)

  assignments TransportAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([vehicleId])
  @@index([isActive])
}

model TransportAssignment {
  id      String         @id @default(cuid())
  routeId String
  route   TransportRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation("StudentTransport", fields: [studentId], references: [id], onDelete: Cascade)

  pickupPoint  String?
  dropoffPoint String?
  direction    TransportDirection @default(BOTH)

  startDate DateTime  @default(now())
  endDate   DateTime?
  isActive  Boolean   @default(true)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, routeId])
  @@index([routeId])
  @@index([studentId])
  @@index([isActive])
}

// ════════════════════════════════════════════════════════════════════════════
// TIMETABLE
// Weekly period schedule per stream per subject paper.
// ════════════════════════════════════════════════════════════════════════════

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model TimetableSlot {
  id String @id @default(cuid())

  streamId String
  stream   Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  // Links to the paper-scoped StreamSubject row (nullable for non-lesson slots)
  streamSubjectId String?
  streamSubject   StreamSubject? @relation(fields: [streamSubjectId], references: [id], onDelete: Cascade)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  termId String
  term   AcademicTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  // Version this slot belongs to
  timetableVersionId String?
  timetableVersion   TimetableVersion? @relation(fields: [timetableVersionId], references: [id], onDelete: Cascade)

  dayOfWeek   DayOfWeek
  slotNumber  Int // ordinal position within the day (1-based)
  startTime   String // "08:00" 24-h format
  endTime     String // "09:00"
  roomNumber  String?
  periodLabel String? // e.g. "Period 3"

  slotType         SlotType @default(LESSON)
  isManualOverride Boolean  @default(false)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([streamId, dayOfWeek, startTime, termId, timetableVersionId])
  @@index([streamId])
  @@index([streamSubjectId])
  @@index([termId])
  @@index([academicYearId])
  @@index([dayOfWeek])
  @@index([timetableVersionId])
  @@index([slotType])
}

// ════════════════════════════════════════════════════════════════════════════
// PROCUREMENT
// Purchase orders and line items for school supplies.
// ════════════════════════════════════════════════════════════════════════════

enum ProcurementStatus {
  DRAFT
  SUBMITTED
  APPROVED
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model ProcurementOrder {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  vendorId String?
  vendor   Vendor? @relation("VendorProcurements", fields: [vendorId], references: [id], onDelete: SetNull)

  orderNumber String  @unique
  title       String
  description String? @db.Text

  status      ProcurementStatus @default(DRAFT)
  totalAmount Float             @default(0)

  requestedById String?
  approvedById  String?
  approvedAt    DateTime?

  orderedAt  DateTime?
  receivedAt DateTime?
  notes      String?   @db.Text

  items ProcurementItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([vendorId])
  @@index([status])
  @@index([orderedAt])
}

model ProcurementItem {
  id      String           @id @default(cuid())
  orderId String
  order   ProcurementOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  name        String
  description String?
  unit        String?
  quantity    Float
  unitPrice   Float
  totalPrice  Float

  receivedQuantity Float   @default(0)
  isFullyReceived  Boolean @default(false)
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
}

// ════════════════════════════════════════════════════════════════════════════
// SCHOOL ASSETS
// Fixed asset register for school property.
// ════════════════════════════════════════════════════════════════════════════

enum AssetStatus {
  ACTIVE
  UNDER_MAINTENANCE
  DISPOSED
  LOST
  DONATED
}

enum AssetCategory {
  FURNITURE
  ELECTRONICS
  SPORTS_EQUIPMENT
  LABORATORY
  KITCHEN
  VEHICLE
  BUILDING_FIXTURE
  MUSICAL_INSTRUMENT
  LIBRARY
  OTHER
}

model SchoolAsset {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name      String
  assetCode String?       @unique
  category  AssetCategory @default(OTHER)
  status    AssetStatus   @default(ACTIVE)

  description  String?
  serialNumber String?
  location     String?
  assignedTo   String? // free-text: "S.4 North lab" or staffId

  purchaseDate   DateTime?
  purchasePrice  Float?
  supplier       String?
  warrantyExpiry DateTime?

  currentValue     Float?
  depreciationRate Float?

  lastMaintenanceAt DateTime?
  nextMaintenanceAt DateTime?
  disposedAt        DateTime?
  disposalReason    String?

  imageUrls String[]
  notes     String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([status])
  @@index([category])
  @@index([assetCode])
}

// ════════════════════════════════════════════════════════════════════════════
// TIMETABLE GENERATION — ENUMS & MODELS
// ════════════════════════════════════════════════════════════════════════════

enum SlotType {
  LESSON
  BREAK
  LUNCH
  ASSEMBLY
  PREP
  FREE
}

enum TimetableStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

// School-level day structure: which days are active and what slots exist
model SchoolDayConfig {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  dayOfWeek DayOfWeek
  isActive  Boolean   @default(true)
  label     String?

  slots SchoolDaySlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, dayOfWeek])
  @@index([schoolId])
}

// Individual time slots within a school day
model SchoolDaySlot {
  id String @id @default(cuid())

  schoolDayConfigId String
  schoolDayConfig   SchoolDayConfig @relation(fields: [schoolDayConfigId], references: [id], onDelete: Cascade)

  slotNumber  Int // 1-based ordinal
  startTime   String // "08:00"
  endTime     String // "09:00"
  slotType    SlotType @default(LESSON)
  label       String?
  durationMin Int      @default(40)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolDayConfigId, slotNumber])
  @@index([schoolDayConfigId])
  @@index([slotType])
}

// Per-class day config override (e.g. classes with PREP lessons)
model ClassDayConfig {
  id          String    @id @default(cuid())
  classYearId String
  classYear   ClassYear @relation(fields: [classYearId], references: [id], onDelete: Cascade)
  schoolId    String

  dayOfWeek DayOfWeek
  isActive  Boolean   @default(true)
  label     String?

  slots ClassDaySlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classYearId, dayOfWeek])
  @@index([classYearId])
  @@index([schoolId])
}

model ClassDaySlot {
  id String @id @default(cuid())

  classDayConfigId String
  classDayConfig   ClassDayConfig @relation(fields: [classDayConfigId], references: [id], onDelete: Cascade)

  slotNumber  Int
  startTime   String
  endTime     String
  slotType    SlotType @default(LESSON)
  label       String?
  durationMin Int      @default(40)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classDayConfigId, slotNumber])
  @@index([classDayConfigId])
}

// Per-ClassSubject timetable generation config
model ClassSubjectConfig {
  id String @id @default(cuid())

  classSubjectId String       @unique
  classSubject   ClassSubject @relation(fields: [classSubjectId], references: [id], onDelete: Cascade)

  lessonsPerWeek Int     @default(3)
  allowDoubles   Boolean @default(false)
  preferMorning  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([classSubjectId])
}

// Teacher availability per day
model TeacherAvailability {
  id        String  @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  schoolId  String

  dayOfWeek     DayOfWeek
  isAvailable   Boolean   @default(true)
  availableFrom String?
  availableTo   String?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teacherId, dayOfWeek])
  @@index([teacherId])
  @@index([schoolId])
}

// Specific blocked slots for a teacher
model TeacherBlockedSlot {
  id        String  @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  schoolId  String

  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  reason    String?
  termId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([schoolId])
  @@index([termId])
}

// A generated timetable version
model TimetableVersion {
  id       String @id @default(cuid())
  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  termId String
  term   AcademicTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  versionNumber Int
  label         String?
  status        TimetableStatus @default(DRAFT)
  generatedAt   DateTime        @default(now())
  publishedAt   DateTime?
  publishedById String?

  slots     TimetableSlot[]
  conflicts TimetableConflict[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, termId, versionNumber])
  @@index([schoolId])
  @@index([termId])
  @@index([academicYearId])
  @@index([status])
}

// Conflicts detected during generation
model TimetableConflict {
  id String @id @default(cuid())

  timetableVersionId String
  timetableVersion   TimetableVersion @relation(fields: [timetableVersionId], references: [id], onDelete: Cascade)

  conflictType String
  severity     String     @default("ERROR")
  description  String
  dayOfWeek    DayOfWeek?
  slotNumber   Int?
  streamId     String?
  teacherId    String?
  subjectId    String?
  isResolved   Boolean    @default(false)
  resolvedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([timetableVersionId])
  @@index([severity])
  @@index([isResolved])
}
