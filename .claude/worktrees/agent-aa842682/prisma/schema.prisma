// ════════════════════════════════════════════════════════════════════════════
// STUDENT SUBJECT ENROLLMENT
// ════════════════════════════════════════════════════════════════════════════

enum SubjectEnrollmentStatus {
  ACTIVE
  DROPPED
  COMPLETED
}

model StudentSubjectEnrollment {
  id String @id @default(cuid())

  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  streamSubjectId String
  streamSubject   StreamSubject @relation(fields: [streamSubjectId], references: [id], onDelete: Cascade)

  enrolledAt     DateTime                @default(now())
  enrolledById   String?
  status         SubjectEnrollmentStatus @default(ACTIVE)
  isCompulsory   Boolean                 @default(true)
  isAutoEnrolled Boolean                 @default(false)

  aoiUnits     AOIUnit[]
  aoiScores    AOIScore[]
  examMarks    ExamMark[]
  marks        Mark[]
  paperResults SubjectPaperResult[]

  subjectResult    SubjectResult?
  subjectFinalMark SubjectFinalMark?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([enrollmentId, streamSubjectId])
  @@index([streamSubjectId])
  @@index([enrollmentId])
  @@index([status])
  @@index([isCompulsory])
}

// ════════════════════════════════════════════════════════════════════════════
// AOI (Activities of Integration)
//
// Computation:
//   1. Each topic has maxPoints (default 3). Student gets a score per topic.
//   2. Average of all topic scores computed.
//   3. (average / maxPoints) × aoiWeight → AOI contribution to final mark.
//   Formula: e.g. avg=2.5, maxPoints=3, aoiWeight=20 → (2.5/3)×20 = 16.67%
// ════════════════════════════════════════════════════════════════════════════

model AOITopic {
  id String @id @default(cuid())

  subjectPaperId String?
  subjectPaper   SubjectPaper? @relation(fields: [subjectPaperId], references: [id], onDelete: Cascade)

  classSubjectId String?
  classSubject   ClassSubject? @relation(fields: [classSubjectId], references: [id], onDelete: Cascade)

  topicNumber Int
  topicName   String
  description String?
  maxPoints   Float   @default(3)

  aoiScores AOIScore[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([subjectPaperId, topicNumber])
  @@unique([classSubjectId, topicNumber])
  @@index([subjectPaperId])
  @@index([classSubjectId])
}

model AOIScore {
  id String @id @default(cuid())

  aoiTopicId String
  aoiTopic   AOITopic @relation(fields: [aoiTopicId], references: [id], onDelete: Cascade)

  studentSubjectEnrollmentId String
  studentSubjectEnrollment   StudentSubjectEnrollment @relation(fields: [studentSubjectEnrollmentId], references: [id], onDelete: Cascade)

  score   Float
  remarks String?

  enteredById String?
  enteredBy   Teacher? @relation("AOIScoreEnteredBy", fields: [enteredById], references: [id])
  enteredAt   DateTime @default(now())

  status       MarkStatus @default(DRAFT)
  approvedById String?
  approvedBy   User?      @relation("AOIScoreApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([aoiTopicId, studentSubjectEnrollmentId])
  @@index([aoiTopicId])
  @@index([studentSubjectEnrollmentId])
  @@index([status])
}

model AOIUnit {
  id String @id @default(cuid())

  studentSubjectEnrollmentId String
  studentSubjectEnrollment   StudentSubjectEnrollment @relation(fields: [studentSubjectEnrollmentId], references: [id], onDelete: Cascade)

  subjectPaperId String?
  subjectPaper   SubjectPaper? @relation(fields: [subjectPaperId], references: [id], onDelete: Cascade)

  unitNumber Int
  score      Float?

  enteredById String?
  enteredBy   Teacher?  @relation("AOIUnitEnteredBy", fields: [enteredById], references: [id])
  enteredAt   DateTime?

  status       MarkStatus @default(DRAFT)
  approvedById String?
  approvedBy   User?      @relation("AOIUnitApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([studentSubjectEnrollmentId, unitNumber, subjectPaperId])
  @@unique([studentSubjectEnrollmentId, unitNumber], name: "studentSubjectEnrollmentId_unitNumber")
  @@index([subjectPaperId])
  @@index([studentSubjectEnrollmentId])
  @@index([status])
}

// ════════════════════════════════════════════════════════════════════════════
// EXAMS & MARKS
// ════════════════════════════════════════════════════════════════════════════

enum ExamType {
  BOT // Beginning of term
  MTE // Midterm exam
  EOT // End of term
  MOCK
  ASSIGNMENT
}

enum MarkStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model Exam {
  id       String    @id @default(cuid())
  name     String
  examType ExamType
  date     DateTime?
  maxMarks Int       @default(100)

  termId String
  term   AcademicTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  classYearId String
  classYear   ClassYear @relation(fields: [classYearId], references: [id], onDelete: Cascade)

  examMarks ExamMark[]
  marks     Mark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([examType, termId, classYearId])
  @@index([classYearId])
  @@index([termId])
}

model ExamMark {
  id String @id @default(cuid())

  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  studentSubjectEnrollmentId String
  studentSubjectEnrollment   StudentSubjectEnrollment @relation(fields: [studentSubjectEnrollmentId], references: [id], onDelete: Cascade)

  // Links to the specific paper. Matches subjectPaperId on the parent StreamSubject row.
  subjectPaperId String?
  subjectPaper   SubjectPaper? @relation(fields: [subjectPaperId], references: [id], onDelete: Cascade)

  marksObtained Float
  outOf         Float @default(100)

  enteredById String?
  enteredBy   Teacher?  @relation("ExamMarkEnteredBy", fields: [enteredById], references: [id])
  enteredAt   DateTime?

  status          MarkStatus @default(DRAFT)
  approvedById    String?
  approvedBy      User?      @relation("ExamMarkApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([examId, studentSubjectEnrollmentId, subjectPaperId])
  @@index([subjectPaperId])
  @@index([examId])
  @@index([studentSubjectEnrollmentId])
  @@index([status])
}

model Mark {
  id            String  @id @default(cuid())
  marksObtained Int
  maxMarks      Int     @default(100)
  grade         String?
  remarks       String?

  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  studentSubjectEnrollmentId String
  studentSubjectEnrollment   StudentSubjectEnrollment @relation(fields: [studentSubjectEnrollmentId], references: [id], onDelete: Cascade)

  enteredById String?
  enteredAt   DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([examId, studentSubjectEnrollmentId])
  @@index([examId])
  @@index([studentSubjectEnrollmentId])
}

// ════════════════════════════════════════════════════════════════════════════
// ASSESSMENT CONFIGURATION — CHANGED
//
// One config per ClassYear per Term. Controls full computation pipeline:
//
//  AOI side (aoiWeight %):
//    hasAOI, maxAOICount (up to 6 topics), aoiMaxPoints (default 3)
//    Computation: avg(scores) / aoiMaxPoints × aoiWeight
//
//  Summative side ((100 − aoiWeight) %):
//    hasBOT / hasMTE / hasEOT — which exams are active
//    botWeight / mteWeight / eotWeight — share within summative pool (active weights sum to 100)
//    1 active exam  → direct (no averaging)
//    2–3 active exams → weighted average within pool
//    Computation: weightedAvg(activeExams) / 100 × (100 − aoiWeight)
//
//  Total = AOI contribution + Summative contribution (max 100%)
// ════════════════════════════════════════════════════════════════════════════

// model ClassAssessmentConfig {
//   id String @id @default(cuid())

//   classYearId String
//   classYear   ClassYear @relation(fields: [classYearId], references: [id], onDelete: Cascade)

//   termId String
//   term   AcademicTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

//   // ── AOI ──────────────────────────────────────────────────────────────────
//   hasAOI       Boolean @default(true)
//   aoiWeight    Float   @default(20)   // % of final mark allocated to AOI
//   maxAOICount  Int     @default(6)    // max AOI topics per subject per term (renamed from maxAOIUnits)
//   aoiMaxPoints Float   @default(3)    // max raw score per AOI topic

//   // ── Summative ─────────────────────────────────────────────────────────────
//   // summativeWeight = 100 − aoiWeight (derived, not stored)
//   hasBOT Boolean @default(false)
//   hasMTE Boolean @default(true)
//   hasEOT Boolean @default(true)

//   // Weights within the summative pool. Active exam weights must sum to 100.
//   // Defaults: MTE+EOT only, 50/50 split
//   botWeight Float @default(0)
//   mteWeight Float @default(50)
//   eotWeight Float @default(50)

//   // REMOVED: assessmentMode (simplified), summativeWeight (now derived),
//   //          useSimpleAverage (replaced by count-based logic)

//   createdAt DateTime @default(now())
//   updatedAt DateTime @default(now())

//   @@unique([classYearId, termId])
//   @@index([classYearId])
//   @@index([termId])
// }

model ClassAssessmentConfig {
  id String @id @default(cuid())

  classYearId String
  classYear   ClassYear @relation(fields: [classYearId], references: [id], onDelete: Cascade)

  termId String
  term   AcademicTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  hasAOI       Boolean @default(true)
  aoiWeight    Float   @default(20)
  maxAOICount  Int     @default(6)
  aoiMaxPoints Float   @default(3)

  hasBOT Boolean @default(false)
  hasMTE Boolean @default(true)
  hasEOT Boolean @default(true)

  botWeight Float @default(0)
  mteWeight Float @default(50)
  eotWeight Float @default(50)

  // ── Lock / unlock ─────────────────────────────────────────────────────────
  isLocked     Boolean   @default(true)
  unlockedById String?
  unlockedBy   User?     @relation("ConfigUnlockedBy", fields: [unlockedById], references: [id])
  unlockedAt   DateTime?
  lockedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([classYearId, termId])
  @@index([classYearId])
  @@index([termId])
  @@index([isLocked])
}

// ════════════════════════════════════════════════════════════════════════════
// GRADING SCALES — CHANGED
// ════════════════════════════════════════════════════════════════════════════

// CHANGED: GradingScaleType added to distinguish O-Level vs A-Level Major scale.
// O_LEVEL        — D1(80–100,1pt) … F9(0–44,9pts) — O-Level and A-Level subsidiary
// A_LEVEL_MAJOR  — A(80–100,6pts) … F(0–39,0pts)  — A-Level principal subjects only
enum GradingScaleType {
  O_LEVEL
  A_LEVEL_MAJOR
}

model SubjectGradingScale {
  id String @id @default(cuid())

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // CHANGED: specifies which scale this subject uses
  gradingScaleType GradingScaleType @default(O_LEVEL)

  boundaries SubjectGradeBoundary[]
  isActive   Boolean                @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([subjectId, schoolId])
  @@index([subjectId])
  @@index([schoolId])
}

model SubjectGradeBoundary {
  id String @id @default(cuid())

  subjectGradingScaleId String
  subjectGradingScale   SubjectGradingScale @relation(fields: [subjectGradingScaleId], references: [id], onDelete: Cascade)

  // O-Level:   "D1" "D2" "C3" "C4" "C5" "C6" "P7" "P8" "F9"
  // A-Level:   "A"  "B"  "C"  "D"  "E"  "O"  "F"
  grade         String
  minPercentage Float
  maxPercentage Float
  // O-Level points: 1(D1)–9(F9). A-Level major: 6(A)–0(F).
  points        Float?
  descriptor    String?

  @@index([subjectGradingScaleId])
}

model AOIGradingScale {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  identifier  Int
  minScore    Float
  maxScore    Float
  descriptor  String
  description String?

  @@unique([schoolId, identifier])
  @@index([schoolId])
}

model GradingConfig {
  id String @id @default(cuid())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // CHANGED: specifies which scale this config applies to.
  // A school will have two GradingConfig rows: one for O_LEVEL, one for A_LEVEL_MAJOR.
  gradingScaleType GradingScaleType @default(O_LEVEL)

  aoiPercentage  Float @default(20)
  aoiMaxPoints   Int   @default(3)
  examPercentage Float @default(80)
  mtePercentage  Float @default(40)
  eotPercentage  Float @default(60)

  gradeBoundaries GradeBoundary[]
  isActive        Boolean         @default(true)

  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  // CHANGED: unique now includes gradingScaleType so one config per scale per year
  @@unique([schoolId, academicYearId, gradingScaleType])
  @@index([schoolId])
  @@index([isActive])
  @@index([gradingScaleType])
}

model GradeBoundary {
  id String @id @default(cuid())

  gradingConfigId String
  gradingConfig   GradingConfig @relation(fields: [gradingConfigId], references: [id], onDelete: Cascade)

  // "D1"–"F9" for O-Level / subsidiary; "A"–"F" for A-Level major
  grade         String
  minPercentage Float
  maxPercentage Float
  // O-Level: 1–9. A-Level major: 6–0.
  points        Float?
  remarks       String?

  @@index([gradingConfigId])
}

// ════════════════════════════════════════════════════════════════════════════
// RESULTS & REPORT CARDS — CHANGED
// ════════════════════════════════════════════════════════════════════════════

// SubjectPaperResult — computed result for one paper of one subject.
// Populated by the assessment computation engine after marks are approved.
model SubjectPaperResult {
  id String @id @default(cuid())

  subjectPaperId String
  subjectPaper   SubjectPaper @relation(fields: [subjectPaperId], references: [id], onDelete: Cascade)

  studentSubjectEnrollmentId String
  studentSubjectEnrollment   StudentSubjectEnrollment @relation(fields: [studentSubjectEnrollmentId], references: [id], onDelete: Cascade)

  // Raw AOI unit scores stored for reference
  u1Score Float?
  u2Score Float?
  u3Score Float?
  u4Score Float?
  u5Score Float?
  u6Score Float?

  // CHANGED: AOI aggregates renamed and clarified
  aoiRawAverage   Float? // average of unit scores (0–aoiMaxPoints)
  aoiContribution Float? // (aoiRawAverage / aoiMaxPoints) × aoiWeight  → % of final mark

  // Exam marks stored for reference
  botMarks Float?
  botOutOf Float?
  mteMarks Float?
  mteOutOf Float?
  eotMarks Float?
  eotOutOf Float?

  // CHANGED: summativeContribution replaces mteWeighted+eotWeighted+summativeTotal
  // = weighted avg of active exams scaled to (100 − aoiWeight)
  summativeContribution Float?

  // CHANGED: totalPercentage replaces totalMark (0–100, not raw marks)
  totalPercentage Float?
  finalGrade      String? // e.g. "C4" or "B"
  gradeDescriptor String? // e.g. "Credit" or "Good"
  gradePoints     Float? // numeric points from grade boundary

  computedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now())

  @@unique([subjectPaperId, studentSubjectEnrollmentId])
  @@index([subjectPaperId])
  @@index([studentSubjectEnrollmentId])
}

// SubjectResult — computed result for a subject (single-paper or pre-combination)
model SubjectResult {
  id String @id @default(cuid())

  studentSubjectEnrollmentId String                   @unique
  studentSubjectEnrollment   StudentSubjectEnrollment @relation(fields: [studentSubjectEnrollmentId], references: [id], onDelete: Cascade)

  u1Score Float?
  u2Score Float?
  u3Score Float?
  u4Score Float?
  u5Score Float?
  u6Score Float?

  aoiRawAverage   Float?
  aoiContribution Float?

  botMarks Float?
  botOutOf Float?
  mteMarks Float?
  mteOutOf Float?
  eotMarks Float?
  eotOutOf Float?

  summativeContribution Float?

  totalPercentage Float?
  finalGrade      String?
  gradeDescriptor String?
  classPosition   Int?
  streamPosition  Int?

  computedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now())

  @@index([studentSubjectEnrollmentId])
}

// SubjectFinalMark — the definitive subject mark after combining all papers.
// This is what appears on the report card per subject.
model SubjectFinalMark {
  id String @id @default(cuid())

  studentSubjectEnrollmentId String                   @unique
  studentSubjectEnrollment   StudentSubjectEnrollment @relation(fields: [studentSubjectEnrollmentId], references: [id], onDelete: Cascade)

  // CHANGED: totalPercentage is now the combined result across papers
  // (sum of paperResult.totalPercentage × paper.weightPercentage / 100)
  totalPercentage Float?
  finalGrade      String? // "D1"–"F9" (O-Level/subsidiary) or "A"–"F" (A-Level major)
  gradeDescriptor String?

  // CHANGED: gradePoints and pointsAwarded both stored
  gradePoints   Float? // raw points from grade boundary lookup
  // pointsAwarded applies grading rules:
  //   O-Level:          1(D1)–9(F9)  — lower = better
  //   A-Level major:    6(A)–0(F)    — higher = better
  //   A-Level subsidiary: 1 if not F9, 0 if F9
  pointsAwarded Float?

  // CHANGED: isSubsidiary copied from Subject.aLevelCategory at compute time
  // for fast report rendering without joins
  isSubsidiary Boolean @default(false)

  classPosition  Int?
  streamPosition Int?
  remarks        String?
  computedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now())

  @@index([studentSubjectEnrollmentId])
}

// CHANGED: ReportCard now stores level snapshot and dual aggregate fields
model ReportCard {
  id String @id @default(cuid())

  enrollmentId String     @unique
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  // CHANGED: snapshot of classLevel at report generation time
  classLevel ClassLevel @default(O_LEVEL)

  totalSubjects  Int?
  totalMarks     Float?
  averageMarks   Float?
  classPosition  Int?
  streamPosition Int?
  outOf          Int?

  // ── O-Level aggregates ────────────────────────────────────────────────────
  // Sum of points for best N subjects (D1=1 pt, F9=9 pts — lower is better)
  aggregatePoints Int?
  // Division I (≤6), II (7–14), III (15–20), IV (21–25), U (>25 or fail)
  division        String?

  // ── A-Level aggregates ────────────────────────────────────────────────────
  // Sum of pointsAwarded: MAJOR subjects 0–6, SUBSIDIARY subjects 0 or 1
  totalPoints      Float?
  principalPasses  Int? // MAJOR subjects with grade D or better (points ≥ 3)
  subsidiaryPasses Int? // SUBSIDIARY subjects with grade P8 or better (not F9)

  classTeacherComment String?
  headTeacherComment  String?

  generatedAt DateTime?
  publishedAt DateTime?
  isPublished Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@index([enrollmentId])
  @@index([isPublished])
  @@index([classLevel])
}

