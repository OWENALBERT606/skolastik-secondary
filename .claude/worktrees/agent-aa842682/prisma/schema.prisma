generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ════════════════════════════════════════════════════════════════════════════
// ENUMS — AUTH & USER
// ════════════════════════════════════════════════════════════════════════════

enum UserType {
  SCHOOL_ADMIN
  STAFF
  STUDENT
  PARENT
}

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  ADMIN
  USER
  TEACHER
  STUDENT
  PARENT
  ACCOUNTANT
  LIBRARIAN
  DOS
  HEAD_TEACHER
  DEPUTY_HEAD
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

// ════════════════════════════════════════════════════════════════════════════
// USER & AUTHENTICATION
// ════════════════════════════════════════════════════════════════════════════

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Role {
  id          String   @id @default(cuid())
  displayName String
  roleName    String   @unique
  description String?
  permissions String[]
  users       User[]   @relation("UserRoles")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([roleName])
}

model User {
  id            String                  @id @default(cuid())
  name          String
  firstName     String
  lastName      String
  phone         String                  @unique
  email         String?                 @unique
  emailVerified DateTime?
  image         String?
  jobTitle      String?
  bio           String?
  roles         Role[]                  @relation("UserRoles")
  password      String?
  status        Boolean                 @default(true)
  accounts      Account[]
  configUnlocks ClassAssessmentConfig[] @relation("ConfigUnlockedBy") // ← ADD THIS
  sessions      Session[]
  schoolAdmins  School[]                @relation("SchoolAdmin")
  isVerfied     Boolean                 @default(false)
  token         String?
  parent        Parent?
  teacher       Teacher?
  student       Student?

  userType UserType @default(SCHOOL_ADMIN)
  loginId  String?

  schoolId String?
  school   School? @relation("SchoolUsers", fields: [schoolId], references: [id], onDelete: SetNull)

  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?

  aoiUnitApprovals  AOIUnit[]  @relation("AOIUnitApprovedBy")
  aoiScoreApprovals AOIScore[] @relation("AOIScoreApprovedBy")
  examMarkApprovals ExamMark[] @relation("ExamMarkApprovedBy")

  assignmentsCreated     StreamSubjectTeacher[]        @relation("AssignmentCreatedBy")
  reassignmentsPerformed StreamSubjectTeacherHistory[] @relation("ReassignedBy")
  transfersMade          EnrollmentTransferHistory[]

  auditLogs               MarkAuditLog[]
  expensesCreated         Expense[]       @relation("ExpenseCreatedBy")
  expensesApproved        Expense[]       @relation("ExpenseApprovedBy")
  stockMovementsPerformed StockMovement[] @relation("MovementPerformedBy")
  storesManaged           Store[]         @relation("StoreManager")

  invoicesCreated  Invoice[]           @relation("InvoiceCreatedBy")
  invoicesVoided   Invoice[]           @relation("InvoiceVoidedBy")
  feeTransactions  FeeTransaction[]    @relation("FeeTransactionCreatedBy")
  installmentPlans InstallmentPlan[]   @relation("InstallmentPlanCreatedBy")
  bursaryApprovals BursaryAllocation[] @relation("BursaryAllocationApprovedBy")
  feeNotifications FeeNotification[]   @relation("FeeNotificationCreatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  roleId    String?

  staffProfiles            Staff[]              @relation("StaffUser")
  contractsIssued          StaffContract[]      @relation("ContractIssuedBy")
  employmentHistoryActions EmploymentHistory[]  @relation("HistoryPerformedBy")
  attendanceEntries        AttendanceRecord[]   @relation("AttendanceEnteredBy")
  overtimesApproved        OvertimeRequest[]    @relation("OvertimeApprovedBy")
  leavesApproved           LeaveRequest[]       @relation("LeaveApprovedBy")
  batchesPrepared          PayrollBatch[]       @relation("BatchPreparedBy")
  batchesApproved          PayrollBatch[]       @relation("BatchApprovedBy")
  advancesApproved         SalaryAdvance[]      @relation("AdvanceApprovedBy")
  loansApproved            StaffLoan[]          @relation("LoanApprovedBy")
  statutoryGenerated       StatutoryReport[]    @relation("StatutoryGeneratedBy")
  documentsVerified        StaffDocument[]      @relation("DocumentVerifiedBy")
  documentsUploaded        StaffDocument[]      @relation("DocumentUploadedBy")
  disciplinaryClosures     DisciplinaryRecord[] @relation("DisciplinaryClosedBy")
  trainingsCreated         TrainingProgram[]    @relation("TrainingCreatedBy")
  exitInterviewsConducted  ExitRecord[]         @relation("ExitInterviewBy")
  exitsApproved            ExitRecord[]         @relation("ExitApprovedBy")

  messagesCreated    Message[]                @relation("MessageCreatedBy")
  messageDeliveries  MessageDelivery[]        @relation("MessageDeliveries")
  systemMessagePosts SystemMessagePost[]      @relation("SystemMessagePosts")
  eventsCreated      SchoolEvent[]            @relation("EventCreatedBy")
  eventRsvps         EventRSVP[]              @relation("EventRSVPs")
  notificationPrefs  NotificationPreference[] @relation("UserNotificationPrefs")
  appNotifications   AppNotification[]        @relation("AppNotifications")

  @@unique([schoolId, loginId])
  @@index([schoolId])
  @@index([userType])
  @@index([loginId])
}

// ════════════════════════════════════════════════════════════════════════════
// MARK AUDIT LOG
// ════════════════════════════════════════════════════════════════════════════

model MarkAuditLog {
  id            String   @id @default(cuid())
  entityType    String
  entityId      String
  action        String
  previousValue Json?
  newValue      Json?
  performedById String
  performedBy   User     @relation(fields: [performedById], references: [id])
  performedAt   DateTime @default(now())
  ipAddress     String?
  userAgent     String?

  @@index([entityType, entityId])
  @@index([performedById])
  @@index([performedAt])
}

// ════════════════════════════════════════════════════════════════════════════
// SCHOOL
// ════════════════════════════════════════════════════════════════════════════

// CHANGED: Added SchoolDivision enum
// Whether the school has O-Level classes, A-Level classes, or both
enum SchoolDivision {
  O_LEVEL
  A_LEVEL
  BOTH
}

model School {
  id       String  @id @default(cuid())
  name     String
  motto    String?
  slug     String  @unique
  code     String  @unique
  address  String?
  contact  String?
  contact2 String?
  contact3 String?
  email    String?
  email2   String?
  website  String?
  logo     String?
  isActive Boolean @default(true)

  // School branding colors stored as hex (e.g. "#1e3a6e")
  primaryColor String?
  accentColor  String?

  // CHANGED: Schools specify which divisions they operate
  division SchoolDivision @default(BOTH)

  adminId String
  admin   User   @relation("SchoolAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  users User[] @relation("SchoolUsers")

  expenseCategories ExpenseCategory[]
  expenses          Expense[]
  vendors           Vendor[]
  stores            Store[]

  academicYears  AcademicYear[]
  classTemplates ClassTemplate[]
  teachers       Teacher[]
  streams        Stream[]
  parents        Parent[]
  subjects       Subject[]
  students       Student[]

  messages          Message[]                @relation("SchoolMessages")
  events            SchoolEvent[]            @relation("SchoolEvents")
  notificationPrefs NotificationPreference[] @relation("SchoolNotificationPrefs")
  appNotifications  AppNotification[]        @relation("SchoolAppNotifications")

  subjectGradingScales SubjectGradingScale[]
  aoiGradingScales     AOIGradingScale[]
  gradingConfigs       GradingConfig[]

  feeCategories      FeeCategory[]
  feeStructures      FeeStructure[]
  studentFeeAccounts StudentFeeAccount[]
  bursaries          Bursary[]
  studentBursaries   StudentBursary[]
  penaltyRules       PenaltyRule[]
  autoInvoiceConfigs AutoInvoiceConfig[]
  feeNotifications   FeeNotification[]

  staff                Staff[]               @relation("SchoolStaff")
  staffRoleDefinitions StaffRoleDefinition[] @relation("SchoolStaffRoles")
  payrolls             Payroll[]             @relation("SchoolPayrolls")
  payrollBatches       PayrollBatch[]        @relation("SchoolPayrollBatches")
  statutoryReports     StatutoryReport[]     @relation("SchoolStatutoryReports")
  appraisalCycles      AppraisalCycle[]      @relation("SchoolAppraisalCycles")
  trainingPrograms     TrainingProgram[]     @relation("SchoolTrainingPrograms")
  staffNotices         StaffNotice[]         @relation("SchoolNotices")
  departments          Department[]
  libraryItems         LibraryItem[]
  vehicles             Vehicle[]
  assets               SchoolAsset[]
  procurementOrders    ProcurementOrder[]

  // Timetable generation back-relations
  schoolDayConfigs  SchoolDayConfig[]
  timetableVersions TimetableVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@index([code])
  @@index([isActive])
}

// ════════════════════════════════════════════════════════════════════════════
// ACADEMIC YEAR & TERM
// ════════════════════════════════════════════════════════════════════════════

model AcademicYear {
  id        String    @id @default(cuid())
  year      String
  isActive  Boolean   @default(true)
  startDate DateTime?
  endDate   DateTime?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  terms              AcademicTerm[]
  enrollments        Enrollment[]
  classYears         ClassYear[]
  gradingConfigs     GradingConfig[]
  teacherEnrollments TeacherYearEnrollment[]

  feeStructures        FeeStructure[]
  studentFeeAccounts   StudentFeeAccount[]
  autoInvoiceConfigs   AutoInvoiceConfig[]
  timetableSlots       TimetableSlot[]
  timetableVersions    TimetableVersion[]
  carryForwardLogsFrom CarryForwardLog[]   @relation("CarryForwardFromYear")
  carryForwardLogsTo   CarryForwardLog[]   @relation("CarryForwardToYear")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([year, schoolId])
  @@index([schoolId])
  @@index([isActive])
}

model AcademicTerm {
  id         String   @id @default(cuid())
  name       String
  termNumber Int
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(true)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  exams             Exam[]
  enrollments       Enrollment[]
  expenses          Expense[]
  streamSubjects    StreamSubject[]
  assessmentConfigs ClassAssessmentConfig[]
  timetableSlots    TimetableSlot[]
  timetableVersions TimetableVersion[]

  feeStructures        FeeStructure[]
  studentFeeAccounts   StudentFeeAccount[]
  autoInvoiceConfigs   AutoInvoiceConfig[]
  carryForwardLogsFrom CarryForwardLog[]   @relation("CarryForwardFromTerm")
  carryForwardLogsTo   CarryForwardLog[]   @relation("CarryForwardToTerm")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([termNumber, academicYearId])
  @@index([academicYearId])
  @@index([isActive])
}

// ════════════════════════════════════════════════════════════════════════════
// CLASS LEVEL — NEW ENUM shared by ClassTemplate, ClassYear
// ════════════════════════════════════════════════════════════════════════════

// Specifies whether a class belongs to O-Level or A-Level.
// Set on ClassTemplate at creation and inherited by ClassYear.
// Drives which grading scale applies to all subjects in that class year.
enum ClassLevel {
  O_LEVEL
  A_LEVEL
}

// ════════════════════════════════════════════════════════════════════════════
// CLASS TEMPLATE
// ════════════════════════════════════════════════════════════════════════════

model ClassTemplate {
  id          String  @id @default(cuid())
  name        String
  code        String?
  description String?

  // Numeric ordering within the level (e.g. S1=1, S2=2 for O-Level; S5=1, S6=2 for A-Level)
  level Int?

  // CHANGED: classLevel specifies whether this is an O-Level or A-Level class.
  // Set at creation and should not change after classes are enrolled.
  classLevel ClassLevel @default(O_LEVEL)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classYears ClassYear[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([name, schoolId])
  @@unique([code, schoolId])
  @@index([schoolId])
  @@index([level])
  @@index([classLevel])
}

// ════════════════════════════════════════════════════════════════════════════
// CLASS YEAR
// ════════════════════════════════════════════════════════════════════════════

model ClassYear {
  id String @id @default(cuid())

  classTemplateId String
  classTemplate   ClassTemplate @relation(fields: [classTemplateId], references: [id], onDelete: Cascade)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  // CHANGED: classLevel inherited from ClassTemplate.classLevel.
  // Stored here for fast querying without join.
  // Drives grading scale, report card aggregates, and subject compatibility validation.
  classLevel ClassLevel @default(O_LEVEL)

  maxStudents    Int?
  classTeacherId String?
  remarks        String?

  assessmentConfigs ClassAssessmentConfig[]
  classSubjects     ClassSubject[]
  streams           Stream[]
  enrollments       Enrollment[]
  exams             Exam[]
  feeStructures     FeeStructure[]
  dayConfigs        ClassDayConfig[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([classTemplateId, academicYearId])
  @@index([academicYearId])
  @@index([classTemplateId])
  @@index([classLevel])
  @@index([isActive])
}

// ════════════════════════════════════════════════════════════════════════════
// STREAM
// ════════════════════════════════════════════════════════════════════════════

model Stream {
  id   String @id @default(cuid())
  name String

  classYearId String
  classYear   ClassYear @relation(fields: [classYearId], references: [id], onDelete: Cascade)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classHeadId String?
  classHead   Teacher? @relation("StreamHead", fields: [classHeadId], references: [id])

  enrollments    Enrollment[]
  streamSubjects StreamSubject[]

  transfersFrom  EnrollmentTransferHistory[] @relation("TransferFrom")
  transfersTo    EnrollmentTransferHistory[] @relation("TransferTo")
  timetableSlots TimetableSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([classYearId, name])
  @@index([classYearId])
  @@index([schoolId])
  @@index([classHeadId])
}

// ════════════════════════════════════════════════════════════════════════════
// TEACHER
// ════════════════════════════════════════════════════════════════════════════

enum TeacherStatus {
  ACTIVE
  ON_LEAVE
  RESIGNED
  RETIRED
  SUSPENDED
  TERMINATED
}

model Teacher {
  id        String        @id @default(cuid())
  staffNo   String        @unique
  firstName String
  lastName  String
  gender    String
  status    TeacherStatus @default(ACTIVE)

  dateOfBirth   DateTime
  nationality   String?
  nationalId    String?  @unique
  maritalStatus String?
  phone         String   @unique
  email         String   @unique
  address       String?

  emergencyContactName  String?
  emergencyRelationship String?
  emergencyPhone        String?
  emergencyEmail        String?

  qualification   String?
  specialization  String?
  teachingLevel   String?
  experienceYears Int?
  previousSchools String[]

  dateOfHire     DateTime
  employmentType String
  role           String

  currentStatus TeacherStatus @default(ACTIVE)
  exitDate      DateTime?
  exitReason    String?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  highestQualification String?
  institutionAttended  String?
  professionalTraining String?
  ongoingStudies       String?

  profilePhoto String?
  documents    String?
  healthInfo   String?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  yearEnrollments          TeacherYearEnrollment[]
  streamSubjectAssignments StreamSubjectTeacher[]
  // CHANGED: paperTeachingAssignments removed — StreamSubjectPaperTeacher deprecated.
  // One StreamSubject row per paper means StreamSubjectTeacher handles paper-level teachers.
  assignmentHistory        StreamSubjectTeacherHistory[] @relation("PreviousTeacher")
  assignmentsTakenOver     StreamSubjectTeacherHistory[] @relation("NewTeacher")
  headedStreams            Stream[]                      @relation("StreamHead")

  // School-wide subject coordinator — NOT a stream-level teaching assignment
  subjectHeadOf Subject[] @relation("SubjectHead")

  aoiUnitsEntered  AOIUnit[]  @relation("AOIUnitEnteredBy")
  aoiScoresEntered AOIScore[] @relation("AOIScoreEnteredBy")
  examMarksEntered ExamMark[] @relation("ExamMarkEnteredBy")

  // Timetable generation back-relations
  availabilities TeacherAvailability[]
  blockedSlots   TeacherBlockedSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  staffId String? @unique
  staff   Staff?  @relation("StaffTeacher", fields: [staffId], references: [id])

  @@index([schoolId])
  @@index([currentStatus])
  @@index([staffNo])
}

// ════════════════════════════════════════════════════════════════════════════
// TEACHER YEAR ENROLLMENT
// ════════════════════════════════════════════════════════════════════════════

enum TeacherYearStatus {
  ACTIVE
  ON_LEAVE
  COMPLETED
  LEFT_MID_YEAR
  TRANSFERRED
  SUSPENDED
}

model TeacherYearEnrollment {
  id String @id @default(cuid())

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  status     TeacherYearStatus @default(ACTIVE)
  startDate  DateTime          @default(now())
  endDate    DateTime?
  exitReason String?
  remarks    String?
  isActive   Boolean           @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@unique([teacherId, academicYearId])
  @@index([teacherId])
  @@index([academicYearId])
  @@index([status])
  @@index([isActive])
}

// ════════════════════════════════════════════════════════════════════════════
// ENUMS — SUBJECTS
// ════════════════════════════════════════════════════════════════════════════

enum SubjectType {
  COMPULSORY
  OPTIONAL
  SUBSIDIARY
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
  REASSIGNED
  CANCELLED
  ON_HOLD
  REMOVED
}

// CHANGED: SubjectLevel replaces the old subjectCategory field on Subject.
// O_LEVEL  — taught only in O-Level classes (graded D1–F9)
// A_LEVEL  — taught only in A-Level classes (MAJOR or SUBSIDIARY)
// BOTH     — taught in both (e.g. English, Mathematics)
enum SubjectLevel {
  O_LEVEL
  A_LEVEL
  BOTH
}

// CHANGED: ALevelCategory determines the grading and point system for A-Level subjects.
// MAJOR      — principal subject, graded A(6pts)–F(0pts)
// SUBSIDIARY — graded D1–F9 like O-Level but contributes flat 1pt if passed, 0 if F9
// null       — indicates a pure O-Level subject (SubjectLevel = O_LEVEL)
enum ALevelCategory {
  MAJOR
  SUBSIDIARY
}

// ════════════════════════════════════════════════════════════════════════════
// SUBJECT
// ════════════════════════════════════════════════════════════════════════════

model Subject {
  id          String  @id @default(cuid())
  name        String
  code        String?
  description String? @db.Text
  category    String?
  isActive    Boolean @default(true)

  // CHANGED: subjectLevel replaces old subjectCategory.
  // Set at subject creation. Determines which class levels this subject can be assigned to
  // and which grading scale is used.
  subjectLevel SubjectLevel @default(O_LEVEL)

  // CHANGED: aLevelCategory is only populated when subjectLevel = A_LEVEL or BOTH.
  // Null for pure O-Level subjects.
  // Admin selects: MAJOR (principal, A-F grading) or SUBSIDIARY (D1-F9 but 1pt flat if passed).
  aLevelCategory ALevelCategory?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  // School-wide subject coordinator — NOT a stream-level teacher assignment.
  // Does not appear on mark entry pages.
  headTeacherId String?
  headTeacher   Teacher? @relation("SubjectHead", fields: [headTeacherId], references: [id], onDelete: SetNull)

  papers         SubjectPaper[]
  classSubjects  ClassSubject[]
  gradingScales  SubjectGradingScale[]
  streamSubjects StreamSubject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, code])
  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([headTeacherId])
  @@index([isActive])
  @@index([subjectLevel])
  @@index([aLevelCategory])
}

// ════════════════════════════════════════════════════════════════════════════
// SUBJECT PAPER
// ════════════════════════════════════════════════════════════════════════════

model SubjectPaper {
  id          String  @id @default(cuid())
  paperNumber Int
  name        String
  description String? @db.Text
  paperCode   String?
  maxMarks    Int     @default(100)

  // Default weight for reference. Per-class weights are in ClassSubjectPaper.weightPercentage.
  weight   Float   @default(1.0)
  aoiCount Int     @default(0)
  isActive Boolean @default(true)

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  // CHANGED: classSubjectPapers back-relation for ClassSubjectPaper
  classSubjectPapers ClassSubjectPaper[]
  streamSubjects     StreamSubject[]
  aoiTopics          AOITopic[]
  aoiUnits           AOIUnit[]
  examMarks          ExamMark[]
  paperResults       SubjectPaperResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subjectId, paperNumber])
  @@unique([subjectId, paperCode])
  @@index([subjectId])
  @@index([isActive])
}

// ════════════════════════════════════════════════════════════════════════════
// CLASS SUBJECT
// ════════════════════════════════════════════════════════════════════════════

model ClassSubject {
  id          String      @id @default(cuid())
  subjectType SubjectType @default(COMPULSORY)

  classYearId String
  classYear   ClassYear @relation(fields: [classYearId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  // CHANGED: classSubjectPapers links which papers this class takes for this subject.
  // weightPercentage across all active rows for this ClassSubject must sum to 100.
  // Single paper → weight defaults to 100. Two papers e.g. P1=60%, P2=40%.
  classSubjectPapers ClassSubjectPaper[]

  aoiCount       Int             @default(0)
  aoiTopics      AOITopic[]
  streamSubjects StreamSubject[]

  // Timetable generation config
  timetableConfig ClassSubjectConfig?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classYearId, subjectId])
  @@index([classYearId])
  @@index([subjectId])
  @@index([subjectType])
}

// ════════════════════════════════════════════════════════════════════════════
// CLASS SUBJECT PAPER — NEW MODEL
// Which papers a class takes for a subject and their weight contribution
// ════════════════════════════════════════════════════════════════════════════

model ClassSubjectPaper {
  id String @id @default(cuid())

  classSubjectId String
  classSubject   ClassSubject @relation(fields: [classSubjectId], references: [id], onDelete: Cascade)

  subjectPaperId String
  subjectPaper   SubjectPaper @relation(fields: [subjectPaperId], references: [id], onDelete: Cascade)

  // % this paper contributes to the final subject mark.
  // Rules (enforced at application layer):
  //   • All active rows for the same ClassSubject MUST sum to exactly 100.
  //   • Single paper → default 100. Two papers e.g. P1=60, P2=40.
  weightPercentage Float @default(100)

  isActive Boolean @default(true)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([classSubjectId, subjectPaperId])
  @@index([classSubjectId])
  @@index([subjectPaperId])
}

// ════════════════════════════════════════════════════════════════════════════
// STREAM SUBJECT
// One row PER PAPER per stream per term (not one row per subject)
// ════════════════════════════════════════════════════════════════════════════

model StreamSubject {
  id          String      @id @default(cuid())
  subjectType SubjectType

  streamId String
  stream   Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  classSubjectId String
  classSubject   ClassSubject @relation(fields: [classSubjectId], references: [id], onDelete: Cascade)

  termId String
  term   AcademicTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  // Required when the subject has papers. One StreamSubject row per paper.
  // Null only for subjects with no SubjectPaper records defined.
  subjectPaperId String?
  subjectPaper   SubjectPaper? @relation(fields: [subjectPaperId], references: [id], onDelete: SetNull)

  // Teacher assignments — one StreamSubjectTeacher per paper-scoped StreamSubject row.
  // StreamSubjectPaperTeacher has been removed — this design replaces it.
  teacherAssignments StreamSubjectTeacher[]
  studentEnrollments StudentSubjectEnrollment[]
  timetableSlots     TimetableSlot[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([streamId, subjectId, termId, subjectPaperId])
  @@index([streamId])
  @@index([subjectId])
  @@index([termId])
  @@index([classSubjectId])
  @@index([subjectPaperId])
  @@index([subjectType])
}

// ════════════════════════════════════════════════════════════════════════════
// STREAM SUBJECT TEACHER
